# =============================================================================
# Chat Recall — Production Environment Variables
# =============================================================================
# Copy this file and fill in real values. NEVER commit the filled-in version.
#
# Variables are grouped by service / concern. Some are shared across services.
# =============================================================================


# -----------------------------------------------------------------------------
# Database (shared: API + MCP)
# -----------------------------------------------------------------------------

# PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:5432/<dbname>
# In production this is an RDS endpoint. Also stored in SSM at
# /chatrecall/production/database-url for use by migrate.sh.
DATABASE_URL=postgresql://recall:CHANGE_ME@your-rds-endpoint.us-west-2.rds.amazonaws.com:5432/chat_recall


# -----------------------------------------------------------------------------
# Authentication (API + Web)
# -----------------------------------------------------------------------------

# Secret used by NextAuth.js to sign JWTs and encrypt session cookies.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=


# -----------------------------------------------------------------------------
# Stripe (API)
# -----------------------------------------------------------------------------

# Stripe secret key (sk_live_...). Found in the Stripe Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=

# Stripe publishable key (pk_live_...). Used on the frontend but referenced here for completeness.
STRIPE_PUBLISHABLE_KEY=

# Stripe webhook signing secret (whsec_...). Found in Stripe Dashboard → Webhooks → Signing secret.
STRIPE_WEBHOOK_SECRET=

# Stripe Price ID for the Chat Recall Pro plan. Found in Stripe Dashboard → Products.
STRIPE_PRICE_ID=

# Stripe Customer Portal URL. Create at Stripe Dashboard → Settings → Billing → Customer portal.
STRIPE_CUSTOMER_PORTAL_URL=


# -----------------------------------------------------------------------------
# App Configuration (API)
# -----------------------------------------------------------------------------

# Comma-separated list of allowed CORS origins for the API.
CORS_ORIGINS=https://chatrecall.ai

# Frontend URL used for redirect links in emails, webhooks, etc.
FRONTEND_URL=https://chatrecall.ai

# Application log level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# Base URL where the MCP recall service is reachable (used by the API for internal calls).
RECALL_BASE_URL=http://chatrecall-mcp.internal:8080


# -----------------------------------------------------------------------------
# MCP Service
# -----------------------------------------------------------------------------

# GitHub OAuth App credentials used by the MCP service for user identity.
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# User ID that the MCP service operates under (for single-tenant / dev use).
RECALL_USER_ID=


# -----------------------------------------------------------------------------
# AWS (Deployment)
# -----------------------------------------------------------------------------

# AWS region for all services (ECR, ECS, RDS, SSM).
AWS_REGION=us-west-2

# ECR repository names (must match what setup-ecr.sh creates).
ECR_REPO_API=chatrecall-api
ECR_REPO_MCP=chatrecall-mcp

# ECS cluster and service names.
ECS_CLUSTER=chatrecall
ECS_SERVICE_API=chatrecall-api
ECS_SERVICE_MCP=chatrecall-mcp


# -----------------------------------------------------------------------------
# Vercel Environment Variables (Web — configure in Vercel Dashboard)
# -----------------------------------------------------------------------------
# These are set in the Vercel project settings, NOT in this file.
# Listed here for reference so all production config is documented in one place.
#
# NEXTAUTH_URL          = https://chatrecall.ai
# NEXTAUTH_SECRET       = (same as above)
# NEXT_PUBLIC_API_URL   = https://api.chatrecall.ai
# GITHUB_ID             = (GitHub OAuth App client ID for web sign-in)
# GITHUB_SECRET         = (GitHub OAuth App client secret for web sign-in)
# GOOGLE_CLIENT_ID      = (Google OAuth client ID)
# GOOGLE_CLIENT_SECRET  = (Google OAuth client secret)
