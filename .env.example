# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=devpassword
DATABASE_URL=postgresql://recall:devpassword@localhost:5432/chat_recall

# ── MCP Server (chat-recall-prod) ────────────────────────────────────────
RECALL_USER_ID=              # Optional: default user ID for stdio mode
RECALL_BASE_URL=             # Required for HTTP+OAuth (e.g. https://recall.example.com)
LOG_LEVEL=INFO

# ── OAuth Providers ──────────────────────────────────────────────────────
GITHUB_CLIENT_ID=            # GitHub OAuth App client ID
GITHUB_CLIENT_SECRET=        # GitHub OAuth App client secret
GOOGLE_CLIENT_ID=            # Google OAuth client ID
GOOGLE_CLIENT_SECRET=        # Google OAuth client secret

# ── Web App (chat-recall-web) ────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-change-me   # Shared between web and API

# ── Stripe (chat-recall-api) ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
